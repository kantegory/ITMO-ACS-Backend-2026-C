							"pm.test('Статус 200', () => pm.response.to.have.status(200));",
							"const body = pm.response.json();",
							"pm.test('Возвращён массив data', () => {",
							"    pm.expect(body).to.have.property('data');",
							"    pm.expect(body.data).to.be.an('array');",
							"});",
							"pm.test('Всего 4 объявления', () => {",
							"    pm.expect(body.pagination.total).to.eql(4);",
							"});",
							"pm.test('Есть пагинация', () => {",
							"    pm.expect(body.pagination).to.have.property('page');",
							"    pm.expect(body.pagination).to.have.property('limit');",
							"    pm.expect(body.pagination).to.have.property('total');",
							"    pm.expect(body.pagination).to.have.property('totalPages');",
							"});",
							"pm.test('У каждого объявления есть город', () => {",
							"    body.data.forEach(p => {",
							"        pm.expect(p).to.have.property('city');",
							"        pm.expect(p.city).to.have.property('name');",
							"    });",
							"});"
