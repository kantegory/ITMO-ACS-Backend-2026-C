	"item": [
		{
			"name": "1. Регистрация владельца",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test('Статус 200', () => pm.response.to.have.status(201));",
							"const body = pm.response.json();",
							"pm.test('Ответ содержит accessToken', () => {",
							"    pm.expect(body).to.have.property('accessToken');",
							"    pm.expect(body.accessToken).to.be.a('string').and.not.empty;",
							"});",
							"pm.test('Ответ содержит refreshToken', () => {",
							"    pm.expect(body).to.have.property('refreshToken');",
							"});",
							"pm.test('Данные пользователя корректны', () => {",
							"    pm.expect(body.user).to.have.property('id');",
							"    pm.expect(body.user.fullName).to.eql('Владелец Иванов');",
							"    pm.expect(body.user.email).to.eql('owner@test.ru');",
							"});",
							"pm.test('Пароль НЕ возвращается', () => {",
							"    pm.expect(body.user).to.not.have.property('password');",
							"});",
							"pm.collectionVariables.set('ownerToken', body.accessToken);",
							"pm.collectionVariables.set('ownerId', body.user.id);"
						],
						"type": "text/javascript",
						"packages": {}
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"email\": \"owner@test.ru\",\n  \"password\": \"pass1234\",\n  \"fullName\": \"Владелец Иванов\"\n}"
				},
				"url": {
					"raw": "{{identityBaseUrl}}/auth/register",
					"host": [
						"{{identityBaseUrl}}"
					],
					"path": [
						"auth",
						"register"
					]
				}
			},
			"response": []
		},
