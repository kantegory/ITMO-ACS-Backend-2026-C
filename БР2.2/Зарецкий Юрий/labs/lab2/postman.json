					"script": {
						"type": "text/javascript",
						"exec": [
							"pm.test('Статус 200', () => pm.response.to.have.status(200));",
							"const body = pm.response.json();",
							"pm.test('Найдено ровно 1 объявление', () => {",
							"    pm.expect(body.pagination.total).to.eql(1);",
							"    pm.expect(body.data).to.have.lengthOf(1);",
							"});",
							"pm.test('Это студия в Москве за 3500', () => {",
							"    const p = body.data[0];",
							"    pm.expect(p.title).to.eql('Уютная студия в центре Москвы');",
							"    pm.expect(p.type).to.eql('flat');",
							"    pm.expect(p.pricePerDay).to.be.at.most(5000);",
							"});",
							"pm.test('Все результаты соответствуют фильтру', () => {",
							"    body.data.forEach(p => {",
							"        pm.expect(p.type).to.eql('flat');",
							"        pm.expect(p.pricePerDay).to.be.at.most(5000);",
							"    });",
							"});",
							"// Выбираем случайное объявление из выдачи",
							"const randomIndex = Math.floor(Math.random() * body.data.length);",
							"const chosen = body.data[randomIndex];",
							"pm.collectionVariables.set('chosenPropertyId', chosen.id);",
							"console.log('Выбрано: [' + chosen.id + '] ' + chosen.title);"
						]
					}
				}
