			"name": "7. Создание объявления — Студия в Москве",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test('Статус 200', () => pm.response.to.have.status(201));",
							"const body = pm.response.json();",
							"pm.test('Объявление создано', () => {",
							"    pm.expect(body).to.have.property('id');",
							"    pm.expect(body.title).to.eql('Уютная студия в центре Москвы');",
							"    pm.expect(body.type).to.eql('flat');",
							"    pm.expect(body.pricePerDay).to.eql(3500);",
							"    pm.expect(body.roomsCount).to.eql(1);",
							"    pm.expect(body.area).to.eql(35);",
							"    pm.expect(body.maxGuests).to.eql(2);",
							"});",
							"pm.test('Привязаны удобства', () => {",
							"    pm.expect(body.comforts).to.be.an('array').with.lengthOf(2);",
							"    const names = body.comforts.map(c => c.name);",
							"    pm.expect(names).to.include('Wi-Fi');",
							"    pm.expect(names).to.include('Кондиционер');",
							"});",
							"pm.collectionVariables.set('property1Id', body.id);"
						],
