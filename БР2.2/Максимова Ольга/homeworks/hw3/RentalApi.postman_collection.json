    {
      "name": "/api/messages",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"есть все поля\", function () {",
              "    const response = pm.response.json();",
              "    pm.expect(response.message).to.have.property('id');",
              "    pm.expect(response.message).to.have.property('sender_id');",
              "    pm.expect(response.message).to.have.property('receiver_id');",
              "    pm.expect(response.message).to.have.property('mes_text');",
              "    pm.expect(response.message.is_read).to.be.false;",
              "    pm.expect(response.message.is_delivered).to.be.false;",
              "});",
              "",
              "",
              "pm.test(\"id получателя совпадает\", function () {",
              "    const response = pm.response.json();",
              "    const requestData = JSON.parse(pm.request.body.raw);",
              "    pm.expect(response.receiver.id).to.equal(requestData.receiver_id);",
              "});",
              "",
              "pm.test(\"текст сообщения совпадает\", function () {",
              "    const response = pm.response.json();",
              "    const requestData = JSON.parse(pm.request.body.raw);",
              "    pm.expect(response.message.mes_text).to.equal(requestData.mes_text);",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
