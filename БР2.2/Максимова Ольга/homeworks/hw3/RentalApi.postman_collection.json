          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Список объявлений\", function () {    ",
              "    const jsonData = pm.response.json();",
              "    pm.expect(jsonData.items).to.be.an('array');",
              "    ",
              "    if (jsonData.items.length > 0) {",
              "        const randomAccom = jsonData.items[Math.floor(Math.random() * jsonData.items.length)];",
              "        pm.collectionVariables.set(\"accomID\", randomAccom.id);",
              "    }",
