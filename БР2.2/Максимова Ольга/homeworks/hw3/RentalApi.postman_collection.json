    {
      "name": "api/messages/me",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Статус 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"Есть все поля\", function () {",
              "    const response = pm.response.json();",
              "    pm.expect(response).to.have.property('items');",
              "    pm.expect(response).to.have.property('total');",
              "    pm.expect(response.items).to.be.an('array');",
              "    pm.expect(response.total).to.be.a('number');",
              "});",
              "",
              "pm.test(\"в сообщениях есть все поля\", function () {",
              "    const response = pm.response.json();",
              "    response.items.forEach(item => {",
              "        pm.expect(item).to.have.property('id');",
              "        pm.expect(item).to.have.property('sender_id');",
              "        pm.expect(item).to.have.property('receiver_id');",
              "        pm.expect(item).to.have.property('mes_text');",
              "        pm.expect(item).to.have.property('mes_type');",
              "        pm.expect(item).to.have.property('is_read');",
              "        pm.expect(item).to.have.property('is_delivered');",
              "        pm.expect(item).to.have.property('sender');",
              "        pm.expect(item).to.have.property('receiver');",
              "    });",
              "});",
              "",
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "auth": {
          "type": "bearer",
